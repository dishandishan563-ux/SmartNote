rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string;
    }

    function isValidNote(data) {
      return data.keys().hasAll(['ownerId', 'title', 'createdAt', 'updatedAt']) &&
             data.ownerId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             (data.content == null || (data.content is string && data.content.size() <= 50000));
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    // Notes
    match /notes/{noteId} {
      allow read: if (isAuthenticated() && (resource.data.ownerId == request.auth.uid || request.auth.uid in resource.data.collaborators)) || (resource.data.isPublic == true);
      allow create: if isAuthenticated() && isValidNote(request.resource.data);
      allow update: if isAuthenticated() && (isDocOwner() || request.auth.uid in resource.data.collaborators) && isValidNote(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }
  }
}
